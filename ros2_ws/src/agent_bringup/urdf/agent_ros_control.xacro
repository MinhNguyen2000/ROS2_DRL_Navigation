<?xml version = "1.0"?>
<robot xmlns:xacro = "http://www.ros.org/wiki/xacro">
    <!-- instantiate the system -->
    <ros2_control name = "GazeboSystem" type = "system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name = "${prefix}_front_left_joint">
            <command_interface name = "velocity">
                <param name = "min">0.0</param>
                <param name = "max">10.0</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>

        <joint name = "${prefix}_front_right_joint">
            <command_interface name = "velocity">
                <param name = "min">0.0</param>
                <param name = "max">10.0</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>

        <joint name = "${prefix}_back_left_joint">
            <command_interface name = "velocity">
                <param name = "min">0.0</param>
                <param name = "max">10.0</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>

        <joint name = "${prefix}_back_right_joint">
            <command_interface name = "velocity">
                <param name = "min">0.0</param>
                <param name = "max">10.0</param>
            </command_interface>
            <state_interface name="velocity"/>
            <state_interface name="position"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin name = "gz_ros2_control::GazeboSimROS2ControlPlugin" filename = "gz_ros2_control-system">
            <robot_param>robot_description</robot_param>
            <robot_param_node>/${prefix}/robot_state_publisher</robot_param_node>
            <parameters>$(find agent_bringup)/config/controllers.yaml</parameters>
            <ros>
                <remapping>/diff_controller/cmd_vel:=/cmd_vel</remapping>
                <remapping>/diff_controller/odom:=/odom</remapping>
                <remapping>/joint_states:=/${prefix}/joint_states</remapping>
            </ros>
        </plugin>
    </gazebo>
</robot>