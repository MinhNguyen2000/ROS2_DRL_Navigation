<?xml version = "1.0"?>
<robot xmlns:xacro = "http://www.ros.org/wiki/xacro">
    <!-- PROPERTIES -->
    <xacro:property name = "mu1" value = "0.50"/>
    <xacro:property name = "mu2" value = "0.01"/>
    <xacro:property name = "minDepth" value = "0.0001"/>
    <xacro:property name = "piValue" value = "3.14159265359"/>

    <!-- LINK REFERENCES-->
    <gazebo reference = "${prefix}_front_right_wheel_link">
        <mu1 value = "${mu1}"/>
        <mu2 value = "${mu2}"/>
        <fdir1>1 0 0</fdir1>
        <minDepth value = "${minDepth}"/>
    </gazebo>

    <gazebo reference = "${prefix}_front_left_wheel_link">
        <mu1 value = "${mu1}"/>
        <mu2 value = "${mu2}"/>
        <fdir1>1 0 0</fdir1>
        <minDepth value = "${minDepth}"/>
    </gazebo>

    <gazebo reference = "${prefix}_back_right_wheel_link">
        <mu1 value = "${mu1}"/>
        <mu2 value = "${mu2}"/>
        <fdir1>1 0 0</fdir1>
        <minDepth value = "${minDepth}"/>
    </gazebo>

    <gazebo reference = "${prefix}_back_left_wheel_link">
        <mu1 value = "${mu1}"/>
        <mu2 value = "${mu2}"/>
        <fdir1>1 0 0</fdir1>
        <minDepth value = "${minDepth}"/>
    </gazebo>

    <!-- PLUGINS -->
    <!-- sensors plugin -->
    <gazebo>
        <plugin name = "ignition::gazebo::systems::Sensors" filename = "ignition-gazebo-sensors-system"/>
    </gazebo>

    <!-- lidar sensor -->
    <gazebo reference = "${prefix}_lidar_link">
        <sensor name = "laser" type = "gpu_lidar">
            <pose>0 0 0.0093 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>1600</samples>
                        <min_angle>${-piValue}</min_angle>
                        <max_angle>${piValue}</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.05</min>
                    <max>12.0</max>
                </range>
            </lidar>
            <topic>scan</topic>
            <gz_frame_id>${prefix}_lidar_link</gz_frame_id>
        </sensor>
    </gazebo>

    <!-- IMU plugin -->
    <gazebo>
        <plugin name = "ignition::gazebo::systems::Imu" filename = "ignition-gazebo-imu-system"/>
    </gazebo>

    <!-- IMU sensor -->
    <gazebo reference = "${prefix}_imu_link">
        <sensor name = "imu_sensor" type = "imu">
            <always_on>1</always_on>
            <update_rate>50</update_rate>
            <visualize>true</visualize>
            <topic>imu_data</topic>
        </sensor>
    </gazebo>
</robot>