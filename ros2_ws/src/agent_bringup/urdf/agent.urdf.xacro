<?xml version = "1.0"?>
<robot name = "agent" xmlns:xacro = "http://www.ros.org/wiki/xacro">
    <!-- ARGUMENTS AND PARAMETERS -->
    <xacro:arg name = "agent_name" default = "agent"/>
    <xacro:property name = "prefix" value = "$(arg agent_name)"/>

    <!-- INCLUDE FILES -->
    <xacro:include filename = "agent_body.xacro"/>
    <!-- <xacro:include filename = "agent_peripherals.xacro"/> -->
    <!-- <xacro:include filename = "agent_gazebo_properties.xacro"/> -->

</robot>